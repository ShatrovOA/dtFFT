# Top-level files
include CMakeLists.txt
include LICENSE
include README.md
include pyproject.toml
include ruff.toml
include setup.py

# CMake modules
recursive-include cmake *

# Public headers
recursive-include include *

# Library sources, interfaces and tests
recursive-include src *
recursive-include tests *

# Exclude unwanted top-level files picked up automatically via git ls-files
exclude .gitattributes
exclude .gitignore
exclude .readthedocs.yaml
exclude codecov.yml

# Exclude entire directories
prune .github
prune benchmark
prune docs
prune _skbuild

# Exclude build/generated artifacts anywhere in the tree
global-exclude *.egg-info
global-exclude *.DS_Store
global-exclude MANIFEST
global-exclude MANIFEST.in
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.a
global-exclude *.o
global-exclude *.mod
global-exclude *.dylib
